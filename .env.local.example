# Copy this file to .env.local and fill in your Neon connection string.
# Get it from: Neon Console -> your project -> Connect -> select branch/role/db
# It will look like:
#   postgresql://alex:AbC123dEf@ep-cool-darkness-a1b2c3d4-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require
#
# Use the POOLED connection string (hostname contains "-pooler") for the app
# at runtime — it's what Next.js's serverless functions should use.
# Use the UNPOOLED string (no "-pooler") for one-off admin scripts like
# running schema.sql / seed.sql, since pgBouncer's transaction-pooling mode
# can break multi-statement scripts.

DATABASE_URL="postgresql://user:password@your-project-pooler.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
